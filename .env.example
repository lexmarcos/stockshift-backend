# ===========================================
# StockShift Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# In production, ALL REQUIRED variables must be set.
# In development, defaults from application-dev.yml are used.

# --- Profile ---
SPRING_PROFILES_ACTIVE=dev

# --- Database (REQUIRED in prod) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stockshift
DB_USER=postgres
DB_PASSWORD=postgres

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT (REQUIRED in prod) ---
# Must be at least 256 bits (32+ characters)
JWT_SECRET=
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAME_SITE=Lax
JWT_COOKIE_DOMAIN=

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:9000

# --- Cloudflare R2 Storage (REQUIRED in prod) ---
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=stockshift
STORAGE_REGION=auto
STORAGE_PUBLIC_URL=

# --- hCaptcha (REQUIRED in prod) ---
HCAPTCHA_SECRET_KEY=
HCAPTCHA_ENABLED=false

# --- OpenAI (REQUIRED in prod) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-nano
